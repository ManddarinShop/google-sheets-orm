{
  "name": "typed-sheets",
  "version": "0.1.0-beta.1",
  "description": "Standalone SQLite entity store and safe Google Sheets sync runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "typed-sheets": "./dist/cli/Cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "apps-script/gateway"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test/*.test.ts"
  },
  "keywords": [
    "google-sheets",
    "typescript",
    "repository",
    "optimistic-locking"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
