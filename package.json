{
  "name": "typed-sheets",
  "version": "0.0.0",
  "description": "Typed repository and safe write layer for Google Sheets-backed MVPs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test/*.test.ts",
    "test:integration": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run test/integration/google-sheets-smoke.test.ts"
  },
  "keywords": [
    "google-sheets",
    "typescript",
    "repository",
    "optimistic-locking"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@googleapis/sheets": "^13.0.2"
  }
}
